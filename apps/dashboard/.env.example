# PostgreSQL/TimescaleDB — server-side only, never NEXT_PUBLIC_
# Dashboard runs on the Windows host, so use 127.0.0.1 (not the Docker service name "postgres")
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=smart_building
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_local_only

# Eclipse Ditto (server-side proxy)
DITTO_URL=http://127.0.0.1:8080

# n8n audit webhook — best-effort fanout from the Command Safety Gate.
# Set N8N_AUDIT_URL (or WEBHOOK_URL) so the dashboard can reach n8n, and set
# N8N_WEBHOOK_SECRET to match the n8n "n8n Webhook Secret" Header Auth credential.
N8N_AUDIT_URL=http://127.0.0.1:5678/webhook/audit-agent
N8N_WEBHOOK_SECRET=change_me_long_random_secret

# Eclipse Ditto client URL. Credentials stay server-side in the /api/ditto proxy.
NEXT_PUBLIC_DITTO_URL=http://127.0.0.1:8080

# MQTT metadata shown by the dashboard. Runtime state still comes from Ditto.
# Canonical topics: elevator/{mqtt_safe_thing_id}/{telemetry|events|commands|status}
# Fleet-wide subscription pattern used by the bridge/agents: elevator/+/telemetry
NEXT_PUBLIC_MQTT_TELEMETRY_TOPIC=elevator/building-floor1-elevator/telemetry
NEXT_PUBLIC_MQTT_STATUS_TOPIC=elevator/building-floor1-elevator/status
NEXT_PUBLIC_THING_ID=building:floor1:elevator
NEXT_PUBLIC_MQTT_ID=building-floor1-elevator
NEXT_PUBLIC_DITTO_SSE_ENABLED=true
NEXT_PUBLIC_COMMAND_TIMEOUT_MS=50000

# Server-derived SCADA operator identity. Client source/role flags are ignored.
DASHBOARD_BASIC_AUTH_USER=operator
DASHBOARD_BASIC_AUTH_PASS=
DASHBOARD_OPERATOR_ROLE=OPERATOR

# /api/system/health probe overrides (all optional; sensible host defaults).
# The dashboard runs on the host, so probes target published ports on
# 127.0.0.1 — NOT docker-internal service names like "mosquitto".
# MQTT probe is a TCP reachability check only (no broker identity used).
#MQTT_HEALTH_HOST=127.0.0.1
#MQTT_HEALTH_PORT=1883
#N8N_HEALTH_URL=http://127.0.0.1:5678/healthz
# Bridge freshness heuristic threshold reuses MICROCONTROLLER_OFFLINE_AFTER_MS
# (default 15000 ms; twin older than 2x this reports bridge as "degraded").
#MICROCONTROLLER_OFFLINE_AFTER_MS=15000

# Optional agent "why" narration (server-side; read by /api/agent/narrate).
# Off by default — the AgentActivityPanel hides the why-card unless LLM_ENABLED=true.
# provider: ollama (local default; dashboard runs on host so use 127.0.0.1) | anthropic
LLM_ENABLED=false
LLM_PROVIDER=ollama
LOCAL_LLM_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=llama3.2
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
