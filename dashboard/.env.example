# PostgreSQL/TimescaleDB — server-side only, never NEXT_PUBLIC_
# Dashboard runs on the Windows host, so use 127.0.0.1 (not the Docker service name "postgres")
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=smart_building
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_local_only

# Eclipse Ditto (server-side proxy)
DITTO_URL=http://127.0.0.1:8080

# Eclipse Ditto (client-side env vars)
NEXT_PUBLIC_DITTO_URL=http://127.0.0.1:8080
NEXT_PUBLIC_MQTT_URL=ws://127.0.0.1:9001
# Canonical MQTT topics: elevator/{mqtt_safe_thing_id}/{telemetry|events|commands|status}
# The dashboard subscribes fleet-wide (single-level wildcard) for telemetry and
# publishes per-device on the commands topic.
NEXT_PUBLIC_MQTT_TELEMETRY_SUBSCRIPTION=elevator/+/telemetry
NEXT_PUBLIC_MQTT_TELEMETRY_TOPIC=elevator/building-floor1-elevator/telemetry
NEXT_PUBLIC_MQTT_COMMANDS_TOPIC=elevator/building-floor1-elevator/commands
# Backwards-compatible single-topic var consumed by mqttClient.js. Comma-separate
# multiple patterns if needed. Prefer the *_SUBSCRIPTION / *_TOPIC variables above.
NEXT_PUBLIC_MQTT_TOPIC=elevator/+/telemetry
NEXT_PUBLIC_THING_ID=building:floor1:elevator
NEXT_PUBLIC_MQTT_ID=building-floor1-elevator
NEXT_PUBLIC_DITTO_USERNAME=ditto
NEXT_PUBLIC_DITTO_PASSWORD=ditto
NEXT_PUBLIC_DITTO_SSE_ENABLED=true
