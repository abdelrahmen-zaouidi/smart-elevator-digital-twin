#pragma once

// --- WiFi --------------------------------------------------------------------
#define SECRET_WIFI_SSID     "YOUR_WIFI_SSID"
#define SECRET_WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// --- MQTT broker -------------------------------------------------------------
#define SECRET_MQTT_SERVER   "192.168.x.y"          // broker IP (must match cert SAN)
#define SECRET_MQTT_USERNAME "esp32-elevator"        // ACL: telemetry-publish / commands-subscribe
#define SECRET_MQTT_PASSWORD "FROM_mosquitto_passwd" // matches mosquitto_config/passwordfile

