# Local Docker runtime
COMPOSE_PROJECT_NAME=smart-elevator-twin
TZ=Europe/Paris

# Postgres / TimescaleDB
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=smart_building
# telemetry_raw retention horizon (migration 008). Keep in sync with the
# add_retention_policy interval in 008_telemetry_retention.sql.
TELEMETRY_RETENTION_DAYS=90

# n8n
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
# Do not set N8N_ENCRYPTION_KEY on an existing n8n volume unless it exactly
# matches the key already stored in /home/node/.n8n/config.
# N8N_ENCRYPTION_KEY=
N8N_USER_MANAGEMENT_DISABLED=false
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_local_only
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
WEBHOOK_URL=http://localhost:5678/
# Shared secret enforced on all internal n8n webhooks (analysis/control/security/
# maintenance/notification/audit-agent). Receivers use a "Header Auth" credential
# (header: x-n8n-webhook-secret); senders attach {{ $env.N8N_WEBHOOK_SECRET }}.
# Set a long random value, mirror it into the n8n credential, THEN re-import the
# auth-enabled workflows. Until both sides match, authed webhooks fail closed.
N8N_WEBHOOK_SECRET=change_me_long_random_secret
# Base URL agents use to call each other's webhooks (env-driven, was hardcoded).
N8N_INTERNAL_URL=http://n8n:5678

# Eclipse Ditto
# Inside Docker, use the Ditto nginx service name. From host, use http://localhost.
DITTO_BASE_URL=http://docker-nginx-1
DITTO_PUBLIC_BASE_URL=http://localhost
DITTO_USERNAME=ditto
DITTO_PASSWORD=ditto
PRIMARY_THING_ID=building:floor1:elevator
# MQTT-safe derivation of PRIMARY_THING_ID. Ditto allows ':' in Thing IDs, but
# ':' is awkward inside MQTT topic segments, so we standardise on '-' here.
# Rule: PRIMARY_MQTT_ID = PRIMARY_THING_ID.replace(':', '-')
PRIMARY_MQTT_ID=building-floor1-elevator
ELEVATOR_FLEET_IDS=building:floor1:elevator

# MQTT / Mosquitto
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_WS_PORT=9001

# Canonical MQTT topic convention:
#   elevator/{mqtt_safe_thing_id}/{telemetry|events|commands|status}
#
# Publish topics (single device — simulator / ESP firmware / dashboard command publisher):
MQTT_TELEMETRY_TOPIC=elevator/building-floor1-elevator/telemetry
MQTT_EVENTS_TOPIC=elevator/building-floor1-elevator/events
MQTT_COMMANDS_TOPIC=elevator/building-floor1-elevator/commands
MQTT_STATUS_TOPIC=elevator/building-floor1-elevator/status
# Subscription patterns (bridge / dashboard for fleet-wide listening):
MQTT_TELEMETRY_SUBSCRIPTION=elevator/+/telemetry
MQTT_EVENTS_SUBSCRIPTION=elevator/+/events
MQTT_COMMANDS_SUBSCRIPTION=elevator/+/commands
MQTT_STATUS_SUBSCRIPTION=elevator/+/status

# Ditto -> MQTT command fanout. Correlated pending_command is the production
# path; legacy feature-leaf forwarding stays disabled to prevent duplicates.
BRIDGE_COMMAND_FORWARDING=true
BRIDGE_LEGACY_LEAF_COMMAND_FORWARDING=false
BRIDGE_COMMAND_INTENT_POLL_INTERVAL_MS=500
BRIDGE_COMMAND_INTENT_MAX_AGE_MS=300000
BRIDGE_COMMAND_ACK_TIMEOUT_MS=45000
# ESP32-S3 dashboard presence detection. Firmware publishes a lightweight
# status heartbeat every 5s; the bridge marks the controller offline after 15s
# without status or telemetry.
MICROCONTROLLER_TELEMETRY_HEARTBEAT_MS=5000
MICROCONTROLLER_OFFLINE_AFTER_MS=15000

# --- MQTT broker auth (security items 1-2) -----------------------------------
# Anonymous access is disabled on the broker. Generate TLS certs with
# scripts/gen-mqtt-certs.sh and the password file with mosquitto_passwd; these
# values MUST match infra/mqtt/passwordfile. Keep real values in .env.
MQTT_HEALTHCHECK_PASSWORD=CHANGE_ME
MQTT_BRIDGE_USERNAME=bridge
MQTT_BRIDGE_PASSWORD=CHANGE_ME
MQTT_AGENTS_USERNAME=agents
MQTT_AGENTS_PASSWORD=CHANGE_ME
# Device identity used by the simulator and the demo profile (mirrors the
# firmware's SECRET_MQTT_USERNAME/SECRET_MQTT_PASSWORD in secrets.h).
# scripts/demo/bootstrap-demo.sh generates this automatically.
MQTT_ESP32_USERNAME=esp32-elevator
MQTT_ESP32_PASSWORD=CHANGE_ME

# Dashboard
DASHBOARD_URL=http://localhost:3000
NEXT_PUBLIC_DITTO_API_BASE=/api/ditto
NEXT_PUBLIC_MQTT_WS_URL=ws://localhost:9001
# Browser-side canonical topics for the Next.js dashboard.
NEXT_PUBLIC_MQTT_TELEMETRY_TOPIC=elevator/building-floor1-elevator/telemetry
NEXT_PUBLIC_MQTT_TELEMETRY_SUBSCRIPTION=elevator/+/telemetry
NEXT_PUBLIC_MQTT_COMMANDS_TOPIC=elevator/building-floor1-elevator/commands
NEXT_PUBLIC_COMMAND_TIMEOUT_MS=50000

# Dashboard operator identity is derived server-side. When a password is set,
# /api/commands validates HTTP Basic Auth independently of middleware.
DASHBOARD_BASIC_AUTH_USER=operator
DASHBOARD_BASIC_AUTH_PASS=
DASHBOARD_OPERATOR_ROLE=OPERATOR

# Agent safety / scheduling
# MAX_RISK_AUTO_CONTROL applies to autonomous (n8n / system) commands;
# MAX_RISK_OPERATOR_CONTROL applies to human (dashboard / operator) commands.
# Safety-critical commands (EMERGENCY_STOP, LOCKDOWN, etc.) bypass both caps
# by declaring max_risk_score:100 in the command catalogue.
MAX_RISK_AUTO_CONTROL=70
MAX_RISK_OPERATOR_CONTROL=85
MAINTENANCE_SCAN_INTERVAL_HOURS=6
NOTIFICATION_ESCALATION_MINUTES=15
NOTIFICATION_DEDUPE_MINUTES=5
RFID_FAILURE_WINDOW_MINUTES=5
RFID_BLACKLIST_THRESHOLD=3
MIN_FLOOR=0
MAX_FLOOR=3
GROUND_FLOOR=0

# Command Safety Gate (deterministic command admission).
# See docs/safety/command-safety-gate.md for the rules each flag controls.
MAX_TWIN_AGE_SECONDS=10
COMMAND_COOLDOWN_SECONDS=3
COMMAND_REQUIRE_REASON=true
COMMAND_AUDIT_ENABLED=true
# Window (seconds) over which an autonomous agent re-issuing the SAME command for
# a sustained condition reuses one command_id (ON CONFLICT update) instead of
# spamming a new control_command_log row + Ditto write each 5s poll. 0 disables.
COMMAND_COALESCE_SECONDS=30
# When true, accepted autonomous control commands ALSO write a durable
# features/control/properties/pending_command intent that the ditto-bridge fans
# out to firmware over MQTT. Default false = twin-state writes only (safe).
AUTONOMOUS_ACTUATION_ENABLED=false

# Optional free local LLM. Disabled by default.
LOCAL_LLM_ENABLED=false
LOCAL_LLM_URL=http://ollama:11434
LOCAL_LLM_MODEL=llama3.2
# Phase 3 LLM aliases (mapped from LOCAL_LLM_* above in docker-compose.yml)
LLM_API_KEY=

# Agent "why" narration (read by the dashboard /api/agent/narrate route).
# Off by default — when LLM_ENABLED!=true the dashboard simply hides the why-card.
# provider: ollama (local, air-gapped, default) | anthropic (set ANTHROPIC_API_KEY)
LLM_ENABLED=true
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
LLM_TIMEOUT_MS=9000
LLM_MAX_TOKENS=512

# Notification channels. Disabled by default unless credentials/URLs are configured.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=elevator-alerts@localhost
EMAIL_TO=operator@localhost
SMS_ENABLED=false
SMS_WEBHOOK_URL=
VOICE_ENABLED=false
VOICE_WEBHOOK_URL=
ALERT_PHONE=

# Simulator (esp32_simulator.py / Docker simulator service)
# THING_ID is read from PRIMARY_THING_ID above; set only to override.
SIMULATOR_PUBLISH_INTERVAL_S=3
# Anomaly profile: normal | noisy | demo | critical | disabled.
# Per-second activation rates; raising the publish interval no longer
# changes how often anomalies fire.
SIM_ANOMALY_PROFILE=normal
# When false (default) emergency_stop, forced_entry, and audio_distress LATCH
# until manually acknowledged. Set true ONLY for academic demos.
SIM_EMERGENCY_AUTO_CLEAR=false
SIM_DEMO_AUTO_CLEAR_S=90
# Set to an integer to make a run fully deterministic (useful for thesis demos
# and unit tests). Leave empty for non-deterministic behaviour.
SIM_RANDOM_SEED=
# Physics sub-step size (seconds). Smaller = more accurate, more CPU.
SIM_PHYSICS_STEP_S=0.1
# Optional overrides; safe defaults are baked into the simulator.
# SIM_NUM_FLOORS=4
# SIM_LOBBY_FLOOR=0
# SIM_FLOOR_HEIGHT_M=3.0
# SIM_MAX_SPEED_MS=1.8
# SIM_ACCEL_MS2=0.6
# SIM_DECEL_MS2=0.6
# SIM_DOOR_OPEN_DWELL_S=4
# SIM_DOOR_TRAVEL_S=2
# SIM_MAX_LOAD_KG=800
# SIM_MOTOR_IDLE_TEMP_C=25
# SIM_MOTOR_MAX_TEMP_C=95
# SIM_MOTOR_HEAT_RATE_C_PER_S=0.3
# SIM_MOTOR_COOL_RATE_C_PER_S=0.15
# SIM_VIBRATION_BASELINE_G=0.05
# SIM_MQTT_KEEPALIVE_S=60
# SIM_MQTT_QOS=1
# SIM_MQTT_PUBLISH_TIMEOUT_S=5
# SIM_INSTANCE_ID=                # auto-generated when empty
# SIM_HEALTH_FILE=runtime/.health  # consumed by Dockerfile.simulator HEALTHCHECK
# SIM_SNAPSHOT_FILE=runtime/live-twin.json
# SIM_LOG_LEVEL=INFO

# Bridge (services/ditto-bridge/bridge.js / Docker bridge service)
# When running the bridge outside Docker, set these to point at localhost.
# Inside Docker these are set automatically by docker-compose.
# MQTT_URL=mqtt://127.0.0.1:1883
# DITTO_URL=http://127.0.0.1:8080
# RFID access-control event mirroring. On every device RFID scan the bridge
# appends an entry to the Ditto accessControl.recentAccessLog ring buffer
# (always). Set BRIDGE_ACCESS_LOG_URL to the dashboard logs endpoint to ALSO
# persist each event to durable Postgres (access_log table, migration 007).
# Leave unset to skip durable mirroring (events still appear via Ditto fallback).
# BRIDGE_ACCESS_LOG_URL=http://host.docker.internal:3000/api/access-control/logs
# ACCESS_LOG_RING_MAX=100

# Optional admin/observability tools
ADMINER_PORT=8081
GRAFANA_PORT=3001
