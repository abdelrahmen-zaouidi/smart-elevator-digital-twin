<mxfile host="app.diagrams.net" agent="Claude Code" version="24.7.8" type="device">
  <diagram id="elevator-electrical-revc" name="General Electrical Schematic (Rev C, A4)">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="0" fold="1" page="1" pageScale="1" pageWidth="2380" pageHeight="1684" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="pagetitle" value="&lt;b&gt;GENERAL ELECTRICAL SCHEMATIC — REDUCED-SCALE ESP32-S3 SMART ELEVATOR PROTOTYPE (4 FLOORS) — REV B&lt;/b&gt;" style="text;html=1;align=center;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="490" y="24" width="1400" height="30" as="geometry" />
        </mxCell>

        <!-- ============ ATX PSU + KCD1 ============ -->
        <mxCell id="atx" value="&lt;b&gt;PS1 — ATX POWER SUPPLY&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#7B2D8E&quot;&gt;&lt;b&gt;STANDBY (always live):&lt;/b&gt; +5VSB purple → ESP32 5V/VIN&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;MAIN RAILS (live only while PS-ON held low):&lt;/b&gt;&lt;br&gt;+12 V yellow — actuator power (motors, fan)&lt;br&gt;+5 V red — module power (relay, LCD TBD)&lt;br&gt;+3.3 V orange — KY-024 sensor bus ONLY&lt;br&gt;&lt;br&gt;GND black — COMMON_GND&lt;br&gt;PS-ON green — active-LOW enable (via SW1 KCD1)" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=8;verticalAlign=top;fontSize=11;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="80" width="430" height="320" as="geometry" />
        </mxCell>
        <mxCell id="kcd1" value="&lt;b&gt;SW1 — KCD1&lt;/b&gt;&lt;br&gt;rocker power switch&lt;br&gt;&lt;i&gt;closes PS-ON to GND → main rails ON&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="490" y="340" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e_pson" value="PS-ON (green, active-LOW)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1A7A1A;strokeWidth=2;fontSize=10;fontColor=#1A7A1A;" edge="1" parent="1" source="atx" target="kcd1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_kcd_gnd" value="to GND (black)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="kcd1" target="atx"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="standbywarn" value="&lt;b&gt;⚠ STANDBY POWER BEHAVIOUR (design check)&lt;/b&gt;&lt;br&gt;When ATX main rails are OFF, the ESP32-S3 stays powered from +5VSB while KY-024 (+3.3 V) and actuator rails are unpowered. Unpowered sensors leave GPIO inputs floating and may be back-powered through their outputs. Firmware should treat sensors as unavailable while main rails are off; protect inputs / ensure safe pull states (series resistors — design check, not fitted)." style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=8;verticalAlign=top;fontSize=10.5;strokeColor=#B45309;fontColor=#7C2D12;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="430" width="430" height="150" as="geometry" />
        </mxCell>

        <!-- ============ ESP32-S3 ============ -->
        <mxCell id="esp32" value="&lt;b&gt;U1 — ESP32-S3-DevKitC-1&lt;/b&gt;&lt;br&gt;central controller — 3.3 V logic, NOT 5 V tolerant (G1)&lt;br&gt;on-module Wi-Fi 2.4 GHz radio (wireless, no cable)&lt;br&gt;&lt;br&gt;&lt;b&gt;Power:&lt;/b&gt; 5V/VIN ← ATX +5VSB · GND ← ATX black&lt;br&gt;3V3 = LDO OUTPUT → RC522, RV1–RV3 (G2)&lt;br&gt;&lt;br&gt;&lt;b&gt;Left:&lt;/b&gt; GPIO8/3/46/0 = KY-024 F0–F3 (C1–C3)&lt;br&gt;GPIO7/15 = door open/closed limits&lt;br&gt;GPIO4/5/6 = ADC1 pots (temp/vib/load proxies)&lt;br&gt;&lt;br&gt;&lt;b&gt;Right:&lt;/b&gt; GPIO39/40 = STEP/DIR · GPIO38/37/36 = door IN1/IN2/EN&lt;br&gt;GPIO16 = fan relay · GPIO19 = buzzer (C5) · GPIO17/18 = I2C&lt;br&gt;GPIO45/20/48/21/47 = RC522 SS(C4)/RST(C5)/SCK/MISO/MOSI&lt;br&gt;&lt;br&gt;&lt;b&gt;Bottom:&lt;/b&gt; GPIO35 = e-stop (C6) · GPIO1/2/42/41 = cabin buttons&lt;br&gt;GPIO9/11/10/13/12/14 = hall buttons&lt;br&gt;&lt;br&gt;&lt;i&gt;strap pins: GPIO0, GPIO3, GPIO45, GPIO46 — native USB: GPIO19/20&lt;br&gt;see GPIO CAUTION NOTES (C1–C6)&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=8;verticalAlign=top;fontSize=10;strokeWidth=2.5;strokeColor=#1F4E79;fontColor=#1F4E79;" vertex="1" parent="1">
          <mxGeometry x="960" y="440" width="450" height="1030" as="geometry" />
        </mxCell>
        <mxCell id="e_5vsb" value="+5VSB (purple) → 5V/VIN — standby, always live" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#7B2D8E;strokeWidth=3.5;fontSize=10;fontColor=#7B2D8E;exitX=1;exitY=0.2;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="atx" target="esp32"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_gnd_esp" value="GND (black) — COMMON_GND (G3)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=3.5;fontSize=10;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="atx" target="esp32"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ============ KY-024 ============ -->
        <mxCell id="grpA" value="PHYSICAL FLOOR CONFIRMATION — KY-024 HALL-EFFECT SENSORS&#10;VCC = ATX +3.3 V orange · DO 3.3 V-safe · polarity bench-test (G4) · debounce in firmware · route away from motor wires (G5)" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;verticalAlign=top;align=left;spacingLeft=8;fontSize=11;fontStyle=1;strokeColor=#2E6B34;fontColor=#2E6B34;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="70" y="590" width="860" height="490" as="geometry" />
        </mxCell>
        <mxCell id="magnet" value="&lt;b&gt;CABIN-MOUNTED MAGNET&lt;/b&gt;&lt;br&gt;permanent magnet on moving cabin&lt;br&gt;&lt;i&gt;magnetic trigger — non-electrical&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;fontSize=10;strokeColor=#777777;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="100" y="770" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ky0" value="&lt;b&gt;U5 — KY-024 F0&lt;/b&gt;&lt;br&gt;VCC ← ATX +3.3 V · GND · OUT" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="560" y="624" width="270" height="96" as="geometry" /></mxCell>
        <mxCell id="ky1" value="&lt;b&gt;U6 — KY-024 F1&lt;/b&gt;&lt;br&gt;VCC ← ATX +3.3 V · GND · OUT" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="560" y="734" width="270" height="96" as="geometry" /></mxCell>
        <mxCell id="ky2" value="&lt;b&gt;U7 — KY-024 F2&lt;/b&gt;&lt;br&gt;VCC ← ATX +3.3 V · GND · OUT" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="560" y="844" width="270" height="96" as="geometry" /></mxCell>
        <mxCell id="ky3" value="&lt;b&gt;U8 — KY-024 F3&lt;/b&gt;&lt;br&gt;VCC ← ATX +3.3 V · GND · OUT" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="560" y="954" width="270" height="96" as="geometry" /></mxCell>
        <mxCell id="e_33_ky0" value="+3.3 V (orange) bus" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#D96D00;strokeWidth=3.5;fontSize=10;fontColor=#D96D00;exitX=1;exitY=0.92;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" edge="1" parent="1" source="atx" target="ky0"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_33_ky1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#D96D00;strokeWidth=3.5;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" edge="1" parent="1" source="ky0" target="ky1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_33_ky2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#D96D00;strokeWidth=3.5;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" edge="1" parent="1" source="ky1" target="ky2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_33_ky3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#D96D00;strokeWidth=3.5;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" edge="1" parent="1" source="ky2" target="ky3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_ky0" value="F0 OUT → GPIO8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.19;entryDx=0;entryDy=0;" edge="1" parent="1" source="ky0" target="esp32"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_ky1" value="F1 OUT → GPIO3 ⚠C2 strap/JTAG" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;fontColor=#B45309;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.23;entryDx=0;entryDy=0;" edge="1" parent="1" source="ky1" target="esp32"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_ky2" value="F2 OUT → GPIO46 ⚠C3 strap" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;fontColor=#B45309;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.27;entryDx=0;entryDy=0;" edge="1" parent="1" source="ky2" target="esp32"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_ky3" value="F3 OUT → GPIO0 ⚠C1 BOOT strap" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;fontColor=#B45309;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.31;entryDx=0;entryDy=0;" edge="1" parent="1" source="ky3" target="esp32"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_mag0" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="magnet" target="ky0"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_mag1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="magnet" target="ky1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_mag2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="magnet" target="ky2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_mag3" value="magnetic coupling (non-electrical)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#999999;fontSize=9;fontColor=#777777;" edge="1" parent="1" source="magnet" target="ky3"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ============ SPDT + TRUTH TABLE ============ -->
        <mxCell id="grpB" value="DOOR END-POSITION CONFIRMATION — SPDT LIMIT SWITCHES" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;verticalAlign=top;align=left;spacingLeft=8;fontSize=11;fontStyle=1;strokeColor=#6B4226;fontColor=#6B4226;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="70" y="1095" width="860" height="300" as="geometry" />
        </mxCell>
        <mxCell id="truthtable" value="&lt;b&gt;Condition | NC contact | GPIO | Meaning&lt;/b&gt;&lt;br&gt;Away from limit | Closed to GND | LOW | Not reached&lt;br&gt;Limit reached | Open | HIGH | End position confirmed&lt;br&gt;Wire broken | Open/floating | HIGH/fault | Requires fault handling&lt;br&gt;&lt;br&gt;• NC wiring with pull-up (COM→GND, NC→GPIO); logic must match firmware&lt;br&gt;• Debounce ≥ 20 ms · both limits active = invalid → fault&lt;br&gt;• No obstruction sensing (G6) · GPIO7/15 not yet in firmware v6 (G4)" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=8;verticalAlign=top;fontSize=10;strokeColor=#6B4226;fontColor=#3D2817;" vertex="1" parent="1">
          <mxGeometry x="90" y="1125" width="450" height="250" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="&lt;b&gt;S1 — DOOR FULLY-OPEN (SPDT)&lt;/b&gt;&lt;br&gt;COM→GND · NC→GPIO7 · NO n.c." style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="560" y="1105" width="270" height="100" as="geometry" /></mxCell>
        <mxCell id="s2" value="&lt;b&gt;S2 — DOOR FULLY-CLOSED (SPDT)&lt;/b&gt;&lt;br&gt;COM→GND · NC→GPIO15 · NO n.c." style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="560" y="1225" width="270" height="100" as="geometry" /></mxCell>
        <mxCell id="e_s1" value="DOOR_OPEN_LIMIT → GPIO7 (pull-up, HIGH at limit)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.4;exitDx=0;exitDy=0;entryX=0;entryY=0.68;entryDx=0;entryDy=0;" edge="1" parent="1" source="s1" target="esp32"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_s2" value="DOOR_CLOSED_LIMIT → GPIO15 (pull-up, HIGH at limit)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.4;exitDx=0;exitDy=0;entryX=0;entryY=0.72;entryDx=0;entryDy=0;" edge="1" parent="1" source="s2" target="esp32"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ============ POTS ============ -->
        <mxCell id="grpC" value="SIMULATED TELEMETRY PROXIES — NOT CALIBRATED SENSORS (ends: ESP32_3V3 / GND; wiper → ADC1)" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;verticalAlign=top;align=left;spacingLeft=8;fontSize=11;fontStyle=1;strokeColor=#444444;fontColor=#444444;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="70" y="1410" width="860" height="215" as="geometry" />
        </mxCell>
        <mxCell id="rv1" value="&lt;b&gt;RV1 10 kΩ&lt;/b&gt;&lt;br&gt;simulated temperature proxy" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="110" y="1440" width="200" height="50" as="geometry" /></mxCell>
        <mxCell id="rv2" value="&lt;b&gt;RV2 10 kΩ&lt;/b&gt;&lt;br&gt;simulated vibration proxy" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="380" y="1490" width="200" height="50" as="geometry" /></mxCell>
        <mxCell id="rv3" value="&lt;b&gt;RV3 10 kΩ&lt;/b&gt;&lt;br&gt;simulated load proxy" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="650" y="1540" width="200" height="50" as="geometry" /></mxCell>
        <mxCell id="e_rv1" value="wiper → GPIO4 (ADC1_CH3)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.82;entryDx=0;entryDy=0;" edge="1" parent="1" source="rv1" target="esp32"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_rv2" value="wiper → GPIO5 (ADC1_CH4)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.86;entryDx=0;entryDy=0;" edge="1" parent="1" source="rv2" target="esp32"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_rv3" value="wiper → GPIO6 (ADC1_CH5)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.9;entryDx=0;entryDy=0;" edge="1" parent="1" source="rv3" target="esp32"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ============ BOTTOM PANELS ============ -->
        <mxCell id="estop" value="&lt;b&gt;S3 — EMERGENCY STOP&lt;/b&gt;&lt;br&gt;push to GND · pull-up · active-LOW (C6)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;strokeColor=#B00000;fontColor=#B00000;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="945" y="1520" width="120" height="130" as="geometry" /></mxCell>
        <mxCell id="cabin" value="&lt;b&gt;CABIN CALL PANEL&lt;/b&gt;&lt;br&gt;4 buttons F0–F3 to common GND&lt;br&gt;internal pull-ups — active-LOW" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1080" y="1520" width="150" height="130" as="geometry" /></mxCell>
        <mxCell id="hall" value="&lt;b&gt;HALL CALL PANELS (LANDINGS)&lt;/b&gt;&lt;br&gt;6 buttons F0▲ F1▲ F1▼ F2▲ F2▼ F3▼ to GND&lt;br&gt;internal pull-ups — active-LOW" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1245" y="1520" width="220" height="130" as="geometry" /></mxCell>
        <mxCell id="e_estop" value="GPIO35" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.08;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="estop" target="esp32"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_cabin" value="GPIO1 / 2 / 42 / 41" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.4;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="cabin" target="esp32"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_hall" value="GPIO9 / 11 / 10 / 13 / 12 / 14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.8;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="hall" target="esp32"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ============ RIGHT COLUMN ============ -->
        <mxCell id="u2" value="&lt;b&gt;U2 — MICROSTEP DRIVER&lt;/b&gt;&lt;br&gt;PUL/STEP · DIR · ENA n.c. (TBD per manual)&lt;br&gt;VMOT — TBD / actuator rail (+12 V shown; verify range) · GND&lt;br&gt;&lt;i&gt;Stepper profile controls travel; KY-024 confirms arrival.&lt;br&gt;Driver current per NEMA17; microstep DIP TBD.&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1560" y="470" width="320" height="175" as="geometry" />
        </mxCell>
        <mxCell id="m1" value="&lt;b&gt;M1&lt;/b&gt;&lt;br&gt;NEMA17 stepper&lt;br&gt;cabin hoist" style="ellipse;whiteSpace=wrap;html=1;fontSize=10;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1902" y="502" width="116" height="116" as="geometry" /></mxCell>
        <mxCell id="e_step" value="GPIO39 → STEP/PUL" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.06;exitDx=0;exitDy=0;entryX=0;entryY=0.17;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="u2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_dir" value="GPIO40 → DIR" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.1;exitDx=0;exitDy=0;entryX=0;entryY=0.4;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="u2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_coils" value="A+ A− B+ B− (coils)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;" edge="1" parent="1" source="u2" target="m1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="u3" value="&lt;b&gt;U3 — L298N / HW-095&lt;/b&gt;&lt;br&gt;dual H-bridge — door drive&lt;br&gt;IN1 · IN2 · ENA/PWM · OUT1/OUT2&lt;br&gt;VS ← actuator rail (+12 V); 5 V logic via on-board reg (jumper, TBD) · GND&lt;br&gt;&lt;i&gt;Door dwell starts only after open-limit (S1) confirmation.&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1560" y="700" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="m2" value="&lt;b&gt;M2&lt;/b&gt;&lt;br&gt;DC door motor" style="ellipse;whiteSpace=wrap;html=1;fontSize=10;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1912" y="724" width="96" height="96" as="geometry" /></mxCell>
        <mxCell id="e_in1" value="GPIO38 → IN1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.17;exitDx=0;exitDy=0;entryX=0;entryY=0.2;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="u3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_in2" value="GPIO37 → IN2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.21;exitDx=0;exitDy=0;entryX=0;entryY=0.45;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="u3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_en" value="GPIO36 → ENA/PWM" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.7;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="u3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_door_out" value="OUT1 / OUT2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;" edge="1" parent="1" source="u3" target="m2"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="k1" value="&lt;b&gt;K1 — JQC3F-05VDC-C&lt;/b&gt;&lt;br&gt;relay module — cooling fan&lt;br&gt;IN (active-LOW, firmware-confirmed) · VCC +5 V (opto/transistor TBD) · GND&lt;br&gt;contacts: COM ← +12 V · NO → fan · NC n.c." style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1560" y="900" width="300" height="140" as="geometry" />
        </mxCell>
        <mxCell id="m3" value="&lt;b&gt;M3&lt;/b&gt;&lt;br&gt;12 V fan" style="ellipse;whiteSpace=wrap;html=1;fontSize=10;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1915" y="923" width="84" height="84" as="geometry" /></mxCell>
        <mxCell id="e_fan_in" value="GPIO16 → IN (active-LOW)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.41;exitDx=0;exitDy=0;entryX=0;entryY=0.35;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="k1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_fan_no" value="NO → +12 V switched" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#A07D00;strokeWidth=2.5;fontSize=10;fontColor=#A07D00;" edge="1" parent="1" source="k1" target="m3"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="bz1" value="&lt;b&gt;BZ1 — ACTIVE BUZZER MODULE, 3.3 V&lt;/b&gt;&lt;br&gt;VCC → ESP32_3V3 (LDO) · GND → COMMON_GND&lt;br&gt;SIG → GPIO19; sinks ON = LOW; OFF = INPUT_PULLUP (C5)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1560" y="1075" width="300" height="55" as="geometry" /></mxCell>
        <mxCell id="e_buzz" value="GPIO19 → buzzer (C5)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.62;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="bz1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="lcd" value="&lt;b&gt;DS1 — LCD 1604A + PCF8574 I2C&lt;/b&gt;&lt;br&gt;address 0x27 · VCC TBD 3.3/5 V ⚠&lt;br&gt;&lt;i&gt;if 5 V module → level shifter on SDA/SCL (G1)&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1560" y="1162" width="320" height="120" as="geometry" /></mxCell>
        <mxCell id="e_sda" value="GPIO17 → SDA (50 kHz)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.4;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="lcd"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_scl" value="GPIO18 → SCL" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.74;exitDx=0;exitDy=0;entryX=0;entryY=0.7;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="lcd"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="rfid" value="&lt;b&gt;U4 — MFRC522 RFID READER&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#B45309&quot;&gt;&lt;b&gt;3.3 V logic ONLY — SPI&lt;/b&gt;&lt;/font&gt;&lt;br&gt;VCC ← ESP32_3V3 (U1 LDO, bench-confirm) · GND&lt;br&gt;security block — RFID access control for cabin/hall calls" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1560" y="1320" width="300" height="210" as="geometry" /></mxCell>
        <mxCell id="e_ss" value="GPIO45 → SDA/SS (C4)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.86;exitDx=0;exitDy=0;entryX=0;entryY=0.12;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="rfid"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_rst" value="GPIO20 → RST (C5)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.9;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="rfid"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_sck" value="GPIO48 → SCK" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.93;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="rfid"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_miso" value="GPIO21 ← MISO" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.96;exitDx=0;exitDy=0;entryX=0;entryY=0.7;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="rfid"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_mosi" value="GPIO47 → MOSI" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;fontSize=10;exitX=1;exitY=0.99;exitDx=0;exitDy=0;entryX=0;entryY=0.88;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="rfid"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ============ GPIO CAUTION NOTES ============ -->
        <mxCell id="cautions" value="&lt;b&gt;⚠ GPIO CAUTION NOTES&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;C1 — GPIO0 (KY-024 F3) — BOOT strap.&lt;/b&gt; Verify KY-024 output level during reset; incorrect level may affect boot mode. Test with cabin magnet parked at F3.&lt;br&gt;&lt;br&gt;&lt;b&gt;C2 — GPIO3 (KY-024 F1) — strap/JTAG.&lt;/b&gt; Strapping/JTAG-sensitive depending on board configuration. Verify reset-state level; avoid unwanted pull during boot.&lt;br&gt;&lt;br&gt;&lt;b&gt;C3 — GPIO46 (KY-024 F2) — strap pin.&lt;/b&gt; Board-specific verification required before final wiring.&lt;br&gt;&lt;br&gt;&lt;b&gt;C4 — GPIO45 (RC522 SS) — strap pin.&lt;/b&gt; VDD_SPI strap; check boot-state pull level with the RFID module connected.&lt;br&gt;&lt;br&gt;&lt;b&gt;C5 — GPIO19/GPIO20 — native USB D−/D+.&lt;/b&gt; Buzzer / RC522 RST may interfere with native USB/JTAG/CDC; verify upload/debug method.&lt;br&gt;&lt;br&gt;&lt;b&gt;C6 — GPIO35/36/37 — board variant.&lt;/b&gt; Unavailable on octal-PSRAM (R8V) modules; verify DevKitC-1 variant.&lt;br&gt;&lt;br&gt;&lt;i&gt;All cautions are design checks for the bench campaign. Keep GPIO43/44 (UART0) free; never use GPIO26–32 (flash/PSRAM).&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=8;verticalAlign=top;fontSize=10;strokeColor=#B45309;fontColor=#3D2817;strokeWidth=2.5;" vertex="1" parent="1">
          <mxGeometry x="2050" y="430" width="306" height="670" as="geometry" />
        </mxCell>

        <!-- ============ SOFTWARE BOUNDARY ============ -->
        <mxCell id="sw" value="&lt;b&gt;SOFTWARE / NETWORK — NOT PHYSICAL WIRING&lt;/b&gt;&lt;br&gt;U1 Wi-Fi 2.4 GHz → MQTT (TLS) → Mosquitto broker&lt;br&gt;→ telemetry bridge → Eclipse Ditto digital twin&lt;br&gt;→ ElevatorOS SCADA dashboard&lt;br&gt;&lt;i&gt;wireless link — no cable&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=10 4 3 4;fontSize=10;strokeColor=#666666;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="1900" y="1160" width="456" height="150" as="geometry" />
        </mxCell>
        <mxCell id="e_wifi" value="wireless (no cable)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;dashPattern=10 4 3 4;strokeColor=#666666;fontSize=9;fontColor=#777777;exitX=1;exitY=0.55;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="esp32" target="sw"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ============ GENERAL NOTES + TITLE BLOCK ============ -->
        <mxCell id="gnotes" value="&lt;b&gt;GENERAL NOTES&lt;/b&gt;&lt;br&gt;G1 ESP32-S3 GPIOs are 3.3 V logic — NOT 5 V tolerant; check every module VCC.&lt;br&gt;G2 Do NOT tie ATX +3.3 V (orange) to ESP32 3V3 LDO output — separate sources, common GND only.&lt;br&gt;G3 All ground symbols are one COMMON_GND node (ATX black).&lt;br&gt;G4 KY-024 / SPDT pins are design assignments, not yet in firmware v6; levels pending bench test.&lt;br&gt;G5 Route sensor/button wiring away from motor/relay wiring; logic and actuator power separated, one ground.&lt;br&gt;G6 Door obstruction sensing is not included in this prototype." style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=8;verticalAlign=top;fontSize=9.5;strokeColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="1480" y="1560" width="876" height="92" as="geometry" />
        </mxCell>
        <mxCell id="titleblock" value="&lt;b&gt;GENERAL ELECTRICAL SCHEMATIC — REV C&lt;/b&gt;&lt;br&gt;Project: Agentic AI-Driven Digital Twin for Smart &amp;amp; Secure Elevator Management&lt;br&gt;Reduced-scale 4-floor ESP32-S3 elevator prototype — master thesis figure&lt;br&gt;Author: Abderrahmane Zaouidi · 2026-06-11&lt;br&gt;Sheet 1/1 (A4 landscape) · Scale NTS · &lt;b&gt;Thesis documentation — not for manufacturing&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=8;verticalAlign=top;fontSize=9.5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="2050" y="1340" width="306" height="180" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
